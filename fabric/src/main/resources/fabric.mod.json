{
  "schemaVersion": 1,
  "id": "protomod",
  "version": "${version}",
  "name": "Protomod",
  "accessWidener": "protomod.accesswidener",
  "description": "Become a protogen!",
  "authors": [
    "downloadableduck"
  ],
  "contact": {
    "homepage": "https://modrinth.com/project/protomod",
    "sources": "https://github.com/downloadableduck/protomod"
  },
  "license": "MIT",
  "icon": "assets/protomod/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.jeff.protomod.fabric.ProtomodFabric"
    ],
    "client": [
      "com.jeff.protomod.fabric.client.ProtomodFabricClient"
    ],
    "modmenu": [
      "com.jeff.protomod.fabric.client.ModMenuIntegration"
    ]
  },
  "mixins": [
    "protomod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.2",
    "minecraft": ">=26.1",
    "java": ">=21",
    "fabric-api": "*",
    "geckolib": "*",
    "modmenu": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
